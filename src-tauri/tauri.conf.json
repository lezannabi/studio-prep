{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Studio Prep",
  "version": "0.1.0",
  "identifier": "com.studioprep.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Studio Prep",
        "width": 1480,
        "height": 980,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "windows": {
      "nsis": {
        "startMenuFolder": "Studio Prep",
        "installerHooks": "./windows/installer-hooks.nsh"
      }
    }
  }
}
